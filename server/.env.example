# ============================================
# Email + SMS Automation System Configuration
# ============================================

# ──────────────────────────────────────────
# MongoDB Configuration
# ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mailflow360

# ──────────────────────────────────────────
# JWT Configuration
# ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ──────────────────────────────────────────
# Google OAuth Configuration (Gmail Integration)
# ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-url.com/api/google/callback

# ──────────────────────────────────────────
# Email Configuration (Platform Sender)
# ──────────────────────────────────────────
PLATFORM_EMAIL=your_email@gmail.com
PLATFORM_EMAIL_PASSWORD=your_app_specific_password_NOT_regular_password

# ──────────────────────────────────────────
# Twilio / WhatsApp Configuration
# ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ──────────────────────────────────────────
# Firebase Admin Configuration
# ──────────────────────────────────────────
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email

# ──────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────
PORT=5000
NODE_ENV=production
API_URL=https://your-backend-url.com
CLIENT_URL=https://your-frontend-url.com

# ──────────────────────────────────────────
# Notification Configuration (Optional)
# ──────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SENTRY_DSN=https://error_reporting@sentry.io/project_id
