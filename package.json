{
  "name": "click2website",
  "version": "1.0.0",
  "description": "Email + SMS Follow-up Automation System",
  "type": "module",
  "scripts": {
    "setup": "bash setup.sh",
    "setup:windows": "call setup.bat",
    "server": "cd server && npm start",
    "server:dev": "cd server && npm run dev",
    "client": "cd client && npm run preview",
    "client:dev": "cd client && npm run dev",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "build": "npm run build --prefix server && npm run build --prefix client",
    "start": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "email",
    "sms",
    "automation",
    "follow-up",
    "crm",
    "engagement"
  ],
  "author": "Web Business Labs",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
